<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>DISCLE — Daily Disc Golf Challenge</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --forest: #152B1E;
    --forest-mid: #1E3D2A;
    --forest-light: #2A5238;
    --birch: #F0EBE1;
    --birch-dim: #C9C3B8;
    --chains: #A8A89A;
    --orange: #E8621A;
    --orange-dim: #b84e14;
    --sky: #7DB5D4;
    --correct: #4CAF7D;
    --wrong: #6B3A3A;
    --text-main: #F0EBE1;
    --text-muted: #8FAF96;
  }

  body {
    background: var(--forest);
    color: var(--text-main);
    font-family: 'Inter', sans-serif;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    background-image:
      radial-gradient(ellipse 80% 50% at 50% -10%, rgba(125,181,212,0.07) 0%, transparent 70%),
      repeating-linear-gradient(0deg, transparent, transparent 40px, rgba(255,255,255,0.015) 40px, rgba(255,255,255,0.015) 41px),
      repeating-linear-gradient(90deg, transparent, transparent 40px, rgba(255,255,255,0.015) 40px, rgba(255,255,255,0.015) 41px);
  }

  /* HEADER */
  header {
    width: 100%;
    max-width: 640px;
    padding: 20px 24px 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .logo { font-family: 'Bebas Neue', sans-serif; font-size: 2.4rem; letter-spacing: 0.08em; color: var(--birch); line-height: 1; }
  .logo span { color: var(--orange); }
  .subtitle { font-size: 0.65rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--text-muted); margin-top: 2px; }
  .header-right { display: flex; gap: 10px; align-items: center; }
  .icon-btn {
    background: var(--forest-mid); border: 1px solid var(--forest-light);
    color: var(--birch-dim); width: 36px; height: 36px; border-radius: 8px;
    cursor: pointer; display: flex; align-items: center; justify-content: center;
    font-size: 1rem; transition: background 0.15s, color 0.15s;
  }
  .icon-btn:hover { background: var(--forest-light); color: var(--birch); }

  /* LOADING */
  .loading-screen {
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    min-height: 60vh; gap: 16px;
  }
  .loading-disc {
    width: 60px; height: 60px; border-radius: 50%;
    border: 3px solid var(--forest-light); border-top-color: var(--orange);
    animation: spin 0.8s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }
  .loading-text { font-family: 'Bebas Neue', sans-serif; font-size: 1.2rem; letter-spacing: 0.1em; color: var(--text-muted); }

  /* DISC VISUAL */
  .disc-area { margin: 20px auto 0; position: relative; width: 140px; height: 140px; }
  .disc-svg { width: 140px; height: 140px; }

  /* CONTEXT CARD */
  .context-card {
    margin: 14px auto 0; max-width: 640px; width: calc(100% - 32px);
    background: var(--forest-mid); border: 1px solid var(--forest-light);
    border-radius: 14px; padding: 12px 20px;
    display: flex; gap: 0; justify-content: space-around;
  }
  .ctx-item { text-align: center; flex: 1; }
  .ctx-divider { width: 1px; background: var(--forest-light); margin: 4px 0; }
  .ctx-label { font-size: 0.58rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--text-muted); margin-bottom: 4px; }
  .ctx-value { font-family: 'Bebas Neue', sans-serif; font-size: 1.2rem; letter-spacing: 0.05em; color: var(--birch); }
  .ctx-badge {
    display: inline-block; font-size: 0.6rem; padding: 2px 7px;
    border-radius: 20px; letter-spacing: 0.1em; text-transform: uppercase; margin-top: 3px;
    font-weight: 600;
  }
  .ctx-badge.yes { background: rgba(76,175,125,0.2); color: var(--correct); border: 1px solid rgba(76,175,125,0.3); }
  .ctx-badge.no { background: rgba(107,58,58,0.2); color: #C08080; border: 1px solid rgba(107,58,58,0.3); }

  /* CLUE GRID */
  .clues-area {
    max-width: 640px; width: calc(100% - 32px);
    margin: 12px auto 0; display: grid;
    grid-template-columns: 1fr 1fr; gap: 8px;
  }
  .clue-card {
    background: var(--forest-mid); border: 1px solid var(--forest-light);
    border-radius: 12px; padding: 12px 14px;
    display: flex; flex-direction: column; gap: 5px;
    position: relative; overflow: hidden;
    transition: border-color 0.3s; min-height: 76px; justify-content: center;
  }
  .clue-card.locked { opacity: 0.4; }
  .clue-card.revealed { border-color: var(--orange); animation: revealPop 0.4s cubic-bezier(0.34,1.56,0.64,1); }
  .clue-card.revealed-old { border-color: rgba(232,98,26,0.4); }
  @keyframes revealPop { 0%{transform:scale(0.95);opacity:0.5} 100%{transform:scale(1);opacity:1} }
  .clue-number { position: absolute; top: 7px; right: 10px; font-family: 'Bebas Neue', sans-serif; font-size: 1.4rem; color: var(--forest-light); line-height: 1; }
  .clue-card.revealed .clue-number, .clue-card.revealed-old .clue-number { color: rgba(232,98,26,0.25); }
  .clue-type { font-size: 0.58rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--text-muted); }
  .clue-value { font-family: 'Bebas Neue', sans-serif; font-size: 1.5rem; color: var(--birch); line-height: 1.1; }
  .clue-card.locked .clue-value { font-size: 1rem; color: var(--forest-light); font-family: 'Inter', sans-serif; font-weight: 600; letter-spacing: 0.06em; }

  /* GUESS SLOTS */
  .guess-area { max-width: 640px; width: calc(100% - 32px); margin: 12px auto 0; }
  .guess-label { font-size: 0.58rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--text-muted); margin-bottom: 7px; }
  .guess-slots { display: flex; flex-direction: column; gap: 6px; margin-bottom: 10px; }
  .guess-slot {
    height: 42px; border-radius: 10px; border: 1px solid var(--forest-light);
    background: var(--forest-mid); display: flex; align-items: center;
    padding: 0 14px; font-size: 0.88rem; color: var(--text-muted);
    font-style: italic; position: relative; transition: all 0.2s;
  }
  .guess-slot.correct { background: rgba(76,175,125,0.15); border-color: var(--correct); color: var(--correct); font-style: normal; font-weight: 600; }
  .guess-slot.wrong { background: rgba(107,58,58,0.2); border-color: #7A4A4A; color: #C08080; font-style: normal; }
  .guess-slot.active { border-color: var(--orange); color: var(--birch); font-style: normal; }
  .guess-slot .slot-icon { position: absolute; right: 12px; font-size: 0.95rem; }

  /* INPUT */
  .input-wrap { display: flex; gap: 8px; position: relative; }
  .disc-input {
    flex: 1; height: 48px; border-radius: 10px; border: 1px solid var(--forest-light);
    background: var(--forest-mid); color: var(--birch);
    font-family: 'Inter', sans-serif; font-size: 0.95rem; padding: 0 16px;
    outline: none; transition: border-color 0.2s;
  }
  .disc-input:focus { border-color: var(--orange); }
  .disc-input::placeholder { color: var(--text-muted); }
  .disc-input:disabled { opacity: 0.4; cursor: not-allowed; }
  .guess-btn {
    height: 48px; padding: 0 20px; background: var(--orange); color: white;
    border: none; border-radius: 10px; font-family: 'Bebas Neue', sans-serif;
    font-size: 1.2rem; letter-spacing: 0.08em; cursor: pointer;
    transition: background 0.15s, transform 0.1s; white-space: nowrap;
  }
  .guess-btn:hover { background: var(--orange-dim); }
  .guess-btn:active { transform: scale(0.97); }
  .guess-btn:disabled { background: var(--forest-light); color: var(--text-muted); cursor: not-allowed; transform: none; }

  /* AUTOCOMPLETE */
  .autocomplete-list {
    position: absolute; bottom: 52px; left: 0; right: 80px;
    background: #1A3828; border: 1px solid var(--orange);
    border-radius: 10px; overflow: hidden; z-index: 100;
    max-height: 210px; overflow-y: auto;
  }
  .autocomplete-list:empty { display: none; }
  .ac-item {
    padding: 9px 14px; cursor: pointer; font-size: 0.88rem;
    display: flex; flex-direction: column; gap: 2px;
    border-bottom: 1px solid rgba(255,255,255,0.06); transition: background 0.1s;
  }
  .ac-item:last-child { border-bottom: none; }
  .ac-item:hover, .ac-item.ac-selected { background: rgba(232,98,26,0.2); }
  .ac-item-name { color: var(--birch); font-weight: 600; }
  .ac-item-sub { color: var(--text-muted); font-size: 0.72rem; }

  /* RESULT SCREEN */
  .result-screen {
    display: none; max-width: 640px; width: calc(100% - 32px);
    margin: 0 auto; padding-bottom: 32px;
  }
  .result-screen.show { display: block; }

  .result-hero {
    border-radius: 16px; padding: 22px; text-align: center; margin-bottom: 12px;
  }
  .result-hero.win { background: rgba(76,175,125,0.1); border: 1px solid rgba(76,175,125,0.35); }
  .result-hero.lose { background: rgba(107,58,58,0.15); border: 1px solid rgba(107,58,58,0.4); }
  .result-headline { font-family: 'Bebas Neue', sans-serif; font-size: 2rem; letter-spacing: 0.1em; margin-bottom: 4px; }
  .result-hero.win .result-headline { color: var(--correct); }
  .result-hero.lose .result-headline { color: #C08080; }
  .result-subline { font-size: 0.82rem; color: var(--birch-dim); margin-bottom: 14px; }

  .disc-reveal-card {
    background: var(--forest); border: 1px solid var(--forest-light);
    border-radius: 12px; padding: 14px 18px; margin: 0 auto 12px;
    max-width: 320px;
  }
  .disc-reveal-name { font-family: 'Bebas Neue', sans-serif; font-size: 2rem; letter-spacing: 0.06em; color: var(--birch); line-height: 1; }
  .disc-reveal-mfr { font-size: 0.78rem; color: var(--text-muted); margin: 3px 0 8px; letter-spacing: 0.06em; text-transform: uppercase; }
  .disc-reveal-flights {
    display: flex; gap: 8px; justify-content: center; margin-top: 8px;
  }
  .flight-pill {
    background: var(--forest-mid); border: 1px solid var(--forest-light);
    border-radius: 8px; padding: 5px 10px; text-align: center; min-width: 48px;
  }
  .flight-pill-num { font-family: 'Bebas Neue', sans-serif; font-size: 1.2rem; color: var(--orange); line-height: 1; }
  .flight-pill-label { font-size: 0.52rem; color: var(--text-muted); letter-spacing: 0.1em; text-transform: uppercase; }

  .guess-trail { display: flex; gap: 6px; justify-content: center; margin: 10px 0 4px; font-size: 1.3rem; }

  /* ACTION CARDS */
  .action-card {
    background: var(--forest-mid); border: 1px solid var(--forest-light);
    border-radius: 14px; padding: 16px 18px; margin-bottom: 10px;
  }
  .action-title { font-size: 0.72rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--text-muted); margin-bottom: 12px; text-align: center; }

  /* I THROW THIS */
  .throw-buttons { display: flex; gap: 10px; }
  .throw-btn {
    flex: 1; height: 46px; border-radius: 10px; border: 1px solid var(--forest-light);
    background: var(--forest); color: var(--birch-dim);
    font-family: 'Inter', sans-serif; font-size: 0.88rem; font-weight: 600;
    cursor: pointer; transition: all 0.15s; display: flex; align-items: center; justify-content: center; gap: 7px;
  }
  .throw-btn:hover { border-color: var(--orange); color: var(--birch); }
  .throw-btn.selected-yes { background: rgba(76,175,125,0.15); border-color: var(--correct); color: var(--correct); }
  .throw-btn.selected-no { background: rgba(107,58,58,0.15); border-color: #7A4A4A; color: #C08080; }
  .throw-stat { text-align: center; margin-top: 10px; font-size: 0.78rem; color: var(--text-muted); display: none; }
  .throw-stat.show { display: block; }
  .throw-stat strong { color: var(--birch); }

  /* DIFFICULTY */
  .diff-buttons { display: flex; gap: 8px; }
  .diff-btn {
    flex: 1; height: 52px; border-radius: 10px; border: 1px solid var(--forest-light);
    background: var(--forest); cursor: pointer; transition: all 0.15s;
    display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 3px;
  }
  .diff-btn:hover { border-color: var(--orange); }
  .diff-btn.selected { border-color: var(--orange); background: rgba(232,98,26,0.12); }
  .diff-emoji { font-size: 1.3rem; }
  .diff-label { font-size: 0.6rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-muted); font-weight: 600; }
  .diff-result { text-align: center; margin-top: 10px; font-size: 0.78rem; color: var(--text-muted); display: none; }
  .diff-result.show { display: block; }
  .diff-bar { display: flex; gap: 4px; margin-top: 6px; height: 6px; border-radius: 4px; overflow: hidden; }
  .diff-bar-seg { height: 100%; border-radius: 4px; transition: width 0.6s ease; }
  .diff-bar-seg.easy { background: var(--correct); }
  .diff-bar-seg.medium { background: var(--orange); }
  .diff-bar-seg.hard { background: #C08080; }
  .diff-bar-labels { display: flex; justify-content: space-between; margin-top: 4px; font-size: 0.65rem; color: var(--text-muted); }

  /* BOTTOM ACTIONS */
  .bottom-actions { display: flex; flex-direction: column; gap: 8px; margin-top: 2px; }
  .action-btn {
    width: 100%; height: 48px; border-radius: 10px; border: none;
    font-family: 'Bebas Neue', sans-serif; font-size: 1.15rem; letter-spacing: 0.08em;
    cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px;
    transition: all 0.15s;
  }
  .action-btn.primary { background: var(--orange); color: white; }
  .action-btn.primary:hover { background: var(--orange-dim); }
  .action-btn.secondary { background: var(--forest-mid); border: 1px solid var(--forest-light); color: var(--birch-dim); }
  .action-btn.secondary:hover { border-color: var(--orange); color: var(--birch); }

  /* COUNTDOWN */
  .countdown-wrap { text-align: center; margin-top: 14px; padding-bottom: 8px; }
  .countdown-label { font-size: 0.6rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--text-muted); margin-bottom: 4px; }
  .countdown-time { font-family: 'Bebas Neue', sans-serif; font-size: 1.8rem; letter-spacing: 0.12em; color: var(--birch); }

  /* ARCHIVE MODAL */
  .modal-overlay {
    display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.75);
    z-index: 500; align-items: center; justify-content: center; padding: 20px;
  }
  .modal-overlay.open { display: flex; }
  .modal {
    background: var(--forest-mid); border: 1px solid var(--forest-light);
    border-radius: 16px; padding: 24px; max-width: 500px; width: 100%;
    position: relative; max-height: 85vh; overflow-y: auto;
  }
  .modal h2 { font-family: 'Bebas Neue', sans-serif; font-size: 1.7rem; letter-spacing: 0.08em; color: var(--orange); margin-bottom: 4px; }
  .modal-close { position: absolute; top: 14px; right: 14px; background: none; border: none; color: var(--chains); font-size: 1.1rem; cursor: pointer; padding: 4px; }
  .modal p { color: var(--birch-dim); font-size: 0.88rem; line-height: 1.6; margin-bottom: 10px; }

  /* STATS */
  .stats-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 8px; margin: 14px 0; }
  .stat-box { background: var(--forest); border-radius: 10px; padding: 12px 8px; text-align: center; }
  .stat-num { font-family: 'Bebas Neue', sans-serif; font-size: 1.9rem; color: var(--birch); line-height: 1; }
  .stat-label { font-size: 0.6rem; color: var(--text-muted); letter-spacing: 0.1em; text-transform: uppercase; margin-top: 3px; }
  .guess-dist { margin-top: 14px; }
  .dist-label { font-size: 0.6rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--text-muted); margin-bottom: 8px; }
  .dist-row { display: flex; align-items: center; gap: 8px; margin-bottom: 5px; font-size: 0.8rem; }
  .dist-num { width: 16px; color: var(--text-muted); text-align: right; font-family: 'Bebas Neue', sans-serif; font-size: 1rem; }
  .dist-bar-wrap { flex: 1; height: 22px; background: var(--forest); border-radius: 4px; overflow: hidden; }
  .dist-bar-fill { height: 100%; background: var(--forest-light); border-radius: 4px; min-width: 4px; transition: width 0.6s ease; display: flex; align-items: center; padding-left: 8px; }
  .dist-bar-fill.highlight { background: var(--orange); }
  .dist-bar-fill span { font-size: 0.72rem; color: var(--birch); font-weight: 600; }

  /* ARCHIVE CALENDAR */
  .archive-grid { display: grid; grid-template-columns: repeat(7,1fr); gap: 6px; margin-top: 12px; }
  .archive-day {
    aspect-ratio: 1; border-radius: 8px; display: flex; align-items: center;
    justify-content: center; font-family: 'Bebas Neue', sans-serif; font-size: 1rem;
    cursor: pointer; border: 1px solid var(--forest-light); background: var(--forest);
    color: var(--text-muted); transition: all 0.15s;
  }
  .archive-day.played-win { background: rgba(76,175,125,0.2); border-color: var(--correct); color: var(--correct); }
  .archive-day.played-lose { background: rgba(107,58,58,0.2); border-color: #7A4A4A; color: #C08080; }
  .archive-day.today { border-color: var(--orange); color: var(--orange); }
  .archive-day.future { opacity: 0.2; cursor: default; }
  .archive-day:not(.future):not(.today):hover { border-color: var(--orange); color: var(--birch); }
  .archive-month-label { font-size: 0.6rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--text-muted); margin: 14px 0 6px; }

  /* ARCHIVE GAME */
  .archive-game-header {
    background: var(--forest); border: 1px solid var(--forest-light);
    border-radius: 10px; padding: 10px 14px; margin-bottom: 12px;
    display: flex; align-items: center; justify-content: space-between;
  }
  .archive-game-label { font-size: 0.65rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--text-muted); }
  .archive-game-date { font-family: 'Bebas Neue', sans-serif; font-size: 1.1rem; color: var(--birch); }
  .back-btn { background: none; border: none; color: var(--text-muted); cursor: pointer; font-size: 0.82rem; display: flex; align-items: center; gap: 4px; }
  .back-btn:hover { color: var(--birch); }

  /* HOW TO PLAY */
  .how-step { background: var(--forest); border-radius: 8px; padding: 10px 14px; margin: 6px 0; font-size: 0.84rem; color: var(--birch); border-left: 3px solid var(--orange); }
  .how-step span { color: var(--text-muted); display: block; font-size: 0.72rem; margin-bottom: 2px; }

  footer { max-width: 640px; width: 100%; text-align: center; padding: 20px 0 28px; color: var(--text-muted); font-size: 0.68rem; letter-spacing: 0.06em; }

  @media (max-width: 420px) {
    .logo { font-size: 2rem; }
    .ctx-value { font-size: 1rem; }
    .clue-value { font-size: 1.3rem; }
    .stats-grid { grid-template-columns: repeat(2,1fr); }
  }
</style>
</head>
<body>

<header>
  <div>
    <div class="logo">DIS<span>C</span>LE</div>
    <div class="subtitle">Daily Disc Golf Challenge</div>
  </div>
  <div class="header-right">
    <button class="icon-btn" onclick="openModal('stats')" title="Stats">📊</button>
    <button class="icon-btn" onclick="openModal('archive')" title="Archive">📅</button>
    <button class="icon-btn" onclick="openModal('how')" title="How to Play">❓</button>
  </div>
</header>

<!-- MAIN GAME AREA -->
<div id="mainGame" style="width:100%;max-width:640px;">
  <div class="loading-screen" id="loadingScreen">
    <div class="loading-disc"></div>
    <div class="loading-text">Loading today's disc…</div>
  </div>

  <div id="gameContent" style="display:none; width:100%;">
    <!-- Disc SVG -->
    <div class="disc-area" style="margin:18px auto 0;">
      <svg class="disc-svg" viewBox="0 0 140 140" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="70" cy="70" r="65" fill="#1E3D2A" stroke="#2A5238" stroke-width="1.5"/>
        <circle cx="70" cy="70" r="50" fill="#172E20" stroke="#2A5238" stroke-width="1"/>
        <circle cx="70" cy="70" r="30" fill="#1A3326" stroke="#2A5238" stroke-width="1"/>
        <circle cx="70" cy="70" r="14" fill="#1E3D2A" stroke="#2A5238" stroke-width="1"/>
        <circle cx="70" cy="70" r="5" fill="#2A5238"/>
        <line x1="70" y1="56" x2="70" y2="84" stroke="#2A5238" stroke-width="1" stroke-dasharray="2 3"/>
        <line x1="56" y1="70" x2="84" y2="70" stroke="#2A5238" stroke-width="1" stroke-dasharray="2 3"/>
        <path d="M 30 58 A 44 44 0 0 1 110 58" stroke="#E8621A" stroke-width="2" fill="none" stroke-linecap="round" opacity="0.35"/>
      </svg>
    </div>

    <!-- Context -->
    <div class="context-card">
      <div class="ctx-item">
        <div class="ctx-label">Year Released</div>
        <div class="ctx-value" id="ctxYear">—</div>
      </div>
      <div class="ctx-divider"></div>
      <div class="ctx-item">
        <div class="ctx-label">Manufacturer</div>
        <div class="ctx-value" id="ctxMfr">—</div>
      </div>
      <div class="ctx-divider"></div>
      <div class="ctx-item">
        <div class="ctx-label">Production</div>
        <div id="ctxProd">—</div>
      </div>
      <div class="ctx-divider"></div>
      <div class="ctx-item">
        <div class="ctx-label">Type</div>
        <div class="ctx-value" id="ctxType">—</div>
      </div>
    </div>

    <!-- Clues -->
