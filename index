<div class="modal-overlay" id="modalHow">
  <div class="modal">
    <button class="modal-close" onclick="closeModal('how')">✕</button>
    <h2>How to Play</h2>
    <p>A mystery disc is revealed each day. You know the <strong>year released</strong>, <strong>manufacturer</strong>, <strong>disc type</strong>, and <strong>production status</strong> from the start.</p>
    <p>Make up to <strong>5 guesses</strong>. Each wrong guess reveals a new clue:</p>
    <div class="how-step"><span>After guess 1</span>Speed rating revealed</div>
    <div class="how-step"><span>After guess 2</span>Glide rating revealed</div>
    <div class="how-step"><span>After guess 3</span>Turn rating revealed</div>
    <div class="how-step"><span>After guess 4</span>Fade rating revealed</div>
    <p style="margin-top:10px;font-size:0.8rem;color:var(--text-muted);">Guesses are filtered to discs from today's manufacturer only. Type to search.</p>
  </div>
</div>

<script>
// ============================================================
//  CONFIG
// ============================================================
// Change this to your actual launch date when ready
const LAUNCH_DATE = "2025-01-01";

// ============================================================
//  CLUE DEFINITIONS
// ============================================================
const CLUE_DEFS = [
  { key: "speed",     label: "Speed",  icon: "⚡", format: d => String(d.speed) },
  { key: "glide",     label: "Glide",  icon: "🌬️", format: d => String(d.glide) },
  { key: "turn",      label: "Turn",   icon: "↪️",  format: d => String(d.turn)  },
  { key: "fade",      label: "Fade",   icon: "↩️",  format: d => String(d.fade)  },
];

// ============================================================
//  STATE
// ============================================================
let DISCS = [];
let todayDisc = null;
let archiveDisc = null;
let isArchiveMode = false;
let archiveDayIndex = null;
let acSelectedIndex = -1;

function getDayIndex(dateStr) {
  const launch = new Date(LAUNCH_DATE);
  const target = new Date(dateStr);
  launch.setHours(0,0,0,0);
  target.setHours(0,0,0,0);
  return Math.floor((target - launch) / 86400000);
}

function getTodayStr() {
  const d = new Date();
  return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;
}

function getStateKey(dayIndex) { return `discle_day_${dayIndex}`; }

function loadDayState(dayIndex) {
  const s = localStorage.getItem(getStateKey(dayIndex));
  return s ? JSON.parse(s) : { guesses: [], cluesRevealed: 0, finished: false, won: false, threwThis: null, difficulty: null };
}

function saveDayState(dayIndex, state) {
  localStorage.setItem(getStateKey(dayIndex), JSON.stringify(state));
}

function loadStats() {
  const s = localStorage.getItem("discle_stats_v2");
  return s ? JSON.parse(s) : { played: 0, won: 0, streak: 0, maxStreak: 0, lastWinDay: null, dist: [0,0,0,0,0,0] };
}

function saveStats(dayIndex, won, guessCount) {
  const stats = loadStats();
  const todayIdx = getDayIndex(getTodayStr());
  if (dayIndex !== todayIdx) return; // don't count archive in stats
  stats.played++;
  if (won) {
    stats.won++;
    stats.dist[guessCount - 1]++;
    if (stats.lastWinDay === dayIndex - 1) {
      stats.streak++;
    } else {
      stats.streak = 1;
    }
    if (stats.streak > stats.maxStreak) stats.maxStreak = stats.streak;
    stats.lastWinDay = dayIndex;
  } else {
    stats.dist[5]++;
    stats.streak = 0;
  }
  localStorage.setItem("discle_stats_v2", JSON.stringify(stats));
}

// ============================================================
//  CSV PARSE
// ============================================================
function parseCSV(text) {
  const lines = text.trim().split('\n');
  const headers = lines[0].split(',').map(h => h.trim().replace(/^"|"$/g, ''));
  return lines.slice(1).map(line => {
    const vals = [];
    let cur = '', inQ = false;
    for (let i = 0; i < line.length; i++) {
      if (line[i] === '"') { inQ = !inQ; }
      else if (line[i] === ',' && !inQ) { vals.push(cur.trim()); cur = ''; }
      else { cur += line[i]; }
    }
    vals.push(cur.trim());
    const obj = {};
    headers.forEach((h, i) => { obj[h] = (vals[i] || '').replace(/^"|"$/g, '').trim(); });
    return obj;
  }).filter(r => r['Disc Name']);
}

function normalizeDisc(row) {
  return {
    id: parseInt(row['ID']) || 0,
    month: row['Month'] || '',
    day: parseInt(row['Day']) || 0,
    name: row['Disc Name'] || '',
    manufacturer: row['Manufacturer'] || '',
    year: row['Year Released'] || '',
    inProduction: row['In Production'] || 'Yes',
    type: row['Disc Type'] || '',
    speed: row['Speed'] || '',
    glide: row['Glide'] || '',
    turn: row['Turn'] || '',
    fade: row['Fade'] || '',
    signature: row['Signature Pro'] || '',
    plastics: row['Plastics'] || '',
  };
}

// ============================================================
//  DISC SELECTION
// ============================================================
function getDiscForDay(dayIndex) {
  if (DISCS.length === 0) return null;
  // If disc has Month+Day scheduling, use that
  // Otherwise fall back to ID-based cycling
  const idx = dayIndex % DISCS.length;
  return DISCS[idx];
}

// ============================================================
//  RENDER
// ============================================================
function renderGame(disc, state, dayIndex) {
  const isTodayMode = dayIndex === getDayIndex(getTodayStr());

  // Context
  document.getElementById('ctxYear').textContent = disc.year || '—';
  document.getElementById('ctxMfr').textContent = disc.manufacturer || '—';
  document.getElementById('ctxType').textContent = shortType(disc.type);
  const prodEl = document.getElementById('ctxProd');
  const isYes = disc.inProduction.toLowerCase() === 'yes';
  prodEl.innerHTML = `<span class="ctx-badge ${isYes ? 'yes' : 'no'}">${isYes ? '✓ In Production' : '✕ Discontinued'}</span>`;

  // Clues
  renderClues(disc, state);
  // Guess slots
  renderGuessSlots(disc, state);
  // Input
  const input = document.getElementById('discInput');
  const btn = document.getElementById('guessBtn');
  if (state.finished) {
    input.disabled = true;
    btn.disabled = true;
    document.getElementById('inputWrap').style.display = 'none';
    renderResultScreen(disc, state, isTodayMode);
  } else {
    input.disabled = false;
    btn.disabled = false;
    document.getElementById('inputWrap').style.display = 'flex';
    document.getElementById('resultScreen').classList.remove('show');
  }
}

function shortType(type) {
  const map = { 'Distance Driver': 'Dist Driver', 'Fairway Driver': 'Fairway', 'Midrange': 'Midrange', 'Putter': 'Putter' };
  return map[type] || type;
}

function renderClues(disc, state) {
  const area = document.getElementById('cluesArea');
  area.innerHTML = '';
  CLUE_DEFS.forEach((clue, i) => {
    const revealed = i < state.cluesRevealed || state.finished;
    const justRevealed = i === state.cluesRevealed - 1 && !state.finished;
    const card = document.createElement('div');
    card.className = 'clue-card' + (revealed ? (justRevealed ? ' revealed' : ' revealed-old') : ' locked');
    card.innerHTML = `
      <div class="clue-number">${i+1}</div>
      <div class="clue-type">${clue.icon} ${clue.label}</div>
      <div class="clue-value">${revealed ? clue.format(disc) : 'Locked'}</div>
    `;
    area.appendChild(card);
  });
}

function renderGuessSlots(disc, state) {
  const slots = document.getElementById('guessSlots');
  slots.innerHTML = '';
  for (let i = 0; i < 5; i++) {
    const slot = document.createElement('div');
    if (i < state.guesses.length) {
      const g = state.guesses[i];
      slot.className = 'guess-slot ' + (g.correct ? 'correct' : 'wrong');
      slot.innerHTML = `${g.name} <span class="slot-icon">${g.correct ? '🎯' : '✗'}</span>`;
    } else if (i === state.guesses.length && !state.finished) {
      slot.className = 'guess-slot active';
      slot.textContent = '← Enter your guess';
    } else {
      slot.className = 'guess-slot';
      slot.textContent = '—';
    }
    slots.appendChild(slot);
  }
}

function renderResultScreen(disc, state, isTodayMode) {
  const screen = document.getElementById('resultScreen');
  screen.classList.add('show');

  const hero = document.getElementById('resultHero');
  hero.className = 'result-hero ' + (state.won ? 'win' : 'lose');

  document.getElementById('resultHeadline').textContent = state.won ? '🎯 Nice Throw!' : 'Out of Bounds';
  document.getElementById('resultSubline').textContent = state.won
    ? `You got it in ${state.guesses.length} guess${state.guesses.length !== 1 ? 'es' : ''}!`
    : 'Better luck tomorrow';

  document.getElementById('discRevealCard').innerHTML = `
    <div class="disc-reveal-name">${disc.name}</div>
    <div class="disc-reveal-mfr">${disc.manufacturer} · ${disc.year}</div>
    <div class="disc-reveal-flights">
      <div class="flight-pill"><div class="flight-pill-num">${disc.speed}</div><div class="flight-pill-label">Speed</div></div>
      <div class="flight-pill"><div class="flight-pill-num">${disc.glide}</div><div class="flight-pill-label">Glide</div></div>
      <div class="flight-pill"><div class="flight-pill-num">${disc.turn}</div><div class="flight-pill-label">Turn</div></div>
      <div class="flight-pill"><div class="flight-pill-num">${disc.fade}</div><div class="flight-pill-label">Fade</div></div>
    </div>
  `;

  const trail = state.guesses.map(g => g.correct ? '🎯' : '❌').join('');
  const empties = state.won ? '⬜'.repeat(5 - state.guesses.length) : '';
  document.getElementById('guesTrail').textContent = trail + empties;

  // Restore throw/diff state
  restoreThrowUI(state);
  restoreDiffUI(state);

  // Countdown (today only)
  if (isTodayMode) {
    document.querySelector('.countdown-wrap').style.display = 'block';
    updateCountdown();
    setInterval(updateCountdown, 1000);
  } else {
    document.querySelector('.countdown-wrap').style.display = 'none';
  }
}

function restoreThrowUI(state) {
  const yesBtn = document.getElementById('throwYes');
  const noBtn = document.getElementById('throwNo');
  const stat = document.getElementById('throwStat');
  yesBtn.className = 'throw-btn' + (state.threwThis === true ? ' selected-yes' : '');
  noBtn.className = 'throw-btn' + (state.threwThis === false ? ' selected-no' : '');
  if (state.threwThis !== null) {
    showThrowStat(stat);
  }
}

function restoreDiffUI(state) {
  ['Easy','Medium','Hard'].forEach(d => {
    document.getElementById('diff'+d).className = 'diff-btn' + (state.difficulty === d.toLowerCase() ? ' selected' : '');
  });
  if (state.difficulty) showDiffResult();
}

// ============================================================
//  THROW THIS / DIFFICULTY
// ============================================================
function getCurrentState() {
  const dayIndex = isArchiveMode ? archiveDayIndex : getDayIndex(getTodayStr());
  return loadDayState(dayIndex);
}

function setCurrentState(state) {
  const dayIndex = isArchiveMode ? archiveDayIndex : getDayIndex(getTodayStr());
  saveDayState(dayIndex, state);
}

function rateThrow(yes) {
  const state = getCurrentState();
  if (state.threwThis !== null) return;
  state.threwThis = yes;
  setCurrentState(state);
  const yesBtn = document.getElementById('throwYes');
  const noBtn = document.getElementById('throwNo');
  yesBtn.className = 'throw-btn' + (yes ? ' selected-yes' : '');
  noBtn.className = 'throw-btn' + (!yes ? ' selected-no' : '');
  showThrowStat(document.getElementById('throwStat'));
}

function showThrowStat(el) {
  // Simulate community stat (in real version this would come from backend)
  el.innerHTML = `<strong>You're not alone</strong> — lots of players throw this disc too.`;
  el.classList.add('show');
}

function rateDiff(level) {
  const state = getCurrentState();
  if (state.difficulty) return;
  state.difficulty = level;
  setCurrentState(state);
  ['Easy','Medium','Hard'].forEach(d => {
    document.getElementById('diff'+d).className = 'diff-btn' + (d.toLowerCase() === level ? ' selected' : '');
  });
  showDiffResult();
}

function showDiffResult() {
  // Simulated community results — replace with real backend data later
  const results = { easy: 30, medium: 45, hard: 25 };
  const total = results.easy + results.medium + results.hard;
  const el = document.getElementById('diffResult');
  el.innerHTML = `
    <div>Community rating</div>
    <div class="diff-bar">
      <div class="diff-bar-seg easy" style="width:${results.easy}%"></div>
      <div class="diff-bar-seg medium" style="width:${results.medium}%"></div>
      <div class="diff-bar-seg hard" style="width:${results.hard}%"></div>
    </div>
    <div class="diff-bar-labels">
      <span>😤 ${results.easy}%</span>
      <span>😐 ${results.medium}%</span>
      <span>😅 ${results.hard}%</span>
    </div>
  `;
  el.classList.add('show');
}

// ============================================================
//  COUNTDOWN
// ============================================================
function updateCountdown() {
  const now = new Date();
  const tomorrow = new Date(now);
  tomorrow.setDate(tomorrow.getDate() + 1);
  tomorrow.setHours(0, 0, 0, 0);
  const diff = tomorrow - now;
  const h = Math.floor(diff / 3600000);
  const m = Math.floor((diff % 3600000) / 60000);
  const s = Math.floor((diff % 60000) / 1000);
  document.getElementById('countdownTime').textContent =
    `${String(h).padStart(2,'0')}:${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`;
}

// ============================================================
//  GUESS LOGIC
// ============================================================
function getActiveDisc() { return isArchiveMode ? archiveDisc : todayDisc; }

function getFilteredDiscs(query) {
  const disc = getActiveDisc();
  if (!disc || !query) return [];
  const q = query.toLowerCase();
  return DISCS.filter(d =>
    d.manufacturer === disc.manufacturer &&
    d.name.toLowerCase().includes(q)
  ).slice(0, 7);
}

function handleInput() {
  acSelectedIndex = -1;
  renderAutocomplete(document.getElementById('discInput').value);
}

function renderAutocomplete(val) {
  const list = document.getElementById('acList');
  list.innerHTML = '';
  if (!val) return;
  getFilteredDiscs(val).forEach(disc => {
    const item = document.createElement('div');
    item.className = 'ac-item';
    item.innerHTML = `<span class="ac-item-name">${disc.name}</span><span class="ac-item-sub">${disc.type} · ${disc.speed}/${disc.glide}/${disc.turn}/${disc.fade}</span>`;
    item.onclick = () => selectAC(disc.name);
    list.appendChild(item);
  });
}

function selectAC(name) {
  document.getElementById('discInput').value = name;
  document.getElementById('acList').innerHTML = '';
  acSelectedIndex = -1;
}

function handleKeydown(e) {
  const items = document.getElementById('acList').querySelectorAll('.ac-item');
  if (e.key === 'ArrowDown') {
    e.preventDefault();
    acSelectedIndex = Math.min(acSelectedIndex + 1, items.length - 1);
    items.forEach((el,i) => el.classList.toggle('ac-selected', i === acSelectedIndex));
  } else if (e.key === 'ArrowUp') {
    e.preventDefault();
    acSelectedIndex = Math.max(acSelectedIndex - 1, 0);
    items.forEach((el,i) => el.classList.toggle('ac-selected', i === acSelectedIndex));
  } else if (e.key === 'Enter') {
    if (acSelectedIndex >= 0 && items[acSelectedIndex]) {
      selectAC(items[acSelectedIndex].querySelector('.ac-item-name').textContent);
    } else {
      submitGuess();
    }
  } else if (e.key === 'Escape') {
    document.getElementById('acList').innerHTML = '';
  }
}

function submitGuess() {
  const disc = getActiveDisc();
  if (!disc) return;
  const dayIndex = isArchiveMode ? archiveDayIndex : getDayIndex(getTodayStr());
  const state = loadDayState(dayIndex);
  if (state.finished) return;

  const input = document.getElementById('discInput');
  const raw = input.value.trim();
  if (!raw) return;

  const match = DISCS.find(d =>
    d.manufacturer === disc.manufacturer &&
    d.name.toLowerCase() === raw.toLowerCase()
  );

  if (!match) {
    input.style.borderColor = '#8B5A5A';
    input.placeholder = 'Not a recognized disc for this manufacturer';
    setTimeout(() => { input.style.borderColor = ''; input.placeholder = 'Type a disc name…'; }, 1200);
    return;
  }

  const correct = match.name === disc.name;
  state.guesses.push({ name: match.name, correct });

  if (correct) {
    state.finished = true;
    state.won = true;
    saveStats(dayIndex, true, state.guesses.length);
  } else if (state.guesses.length >= 5) {
    state.finished = true;
    state.won = false;
    saveStats(dayIndex, false, state.guesses.length);
  } else {
    state.cluesRevealed = state.guesses.length;
  }

  saveDayState(dayIndex, state);
  input.value = '';
  document.getElementById('acList').innerHTML = '';
  renderGame(disc, state, dayIndex);
}

// ============================================================
//  SHARE
// ============================================================
function shareResult() {
  const disc = getActiveDisc();
  const dayIndex = isArchiveMode ? archiveDayIndex : getDayIndex(getTodayStr());
  const state = loadDayState(dayIndex);
  const trail = state.guesses.map(g => g.correct ? '🎯' : '❌').join('');
  const empties = state.won ? '⬜'.repeat(5 - state.guesses.length) : '';
  const text = `DISCLE ${getTodayStr()}\n${disc.manufacturer} · ${disc.year}\n${trail}${empties}\n\ndiscle.app`;
  if (navigator.share) {
    navigator.share({ text }).catch(() => fallbackCopy(text));
  } else {
    fallbackCopy(text);
  }
}

function fallbackCopy(text) {
  navigator.clipboard.writeText(text).then(() => {
    const btn = document.querySelector('.action-btn.primary');
    const orig = btn.textContent;
    btn.textContent = '✓ Copied!';
    setTimeout(() => btn.textContent = orig, 2000);
  });
}

// ============================================================
//  MODALS
// ============================================================
function openModal(id) {
  if (id === 'stats') renderStatsModal();
  if (id === 'archive') renderArchiveModal();
  document.getElementById('modal' + id.charAt(0).toUpperCase() + id.slice(1)).classList.add('open');
}
function closeModal(id) {
  document.getElementById('modal' + id.charAt(0).toUpperCase() + id.slice(1)).classList.remove('open');
  if (id === 'archive' && isArchiveMode) exitArchiveMode();
}
document.querySelectorAll('.modal-overlay').forEach(el => {
  el.addEventListener('click', e => {
    if (e.target === el) {
      el.classList.remove('open');
      if (isArchiveMode) exitArchiveMode();
    }
  });
});

function renderStatsModal() {
  const stats = loadStats();
  const pct = stats.played ? Math.round(stats.won / stats.played * 100) : 0;
  const avg = stats.played ? (stats.dist.reduce((a,v,i) => a + v*(i+1), 0) / Math.max(stats.won,1)).toFixed(1) : '—';
  document.getElementById('statsGrid').innerHTML = `
    <div class="stat-box"><div class="stat-num">${stats.played}</div><div class="stat-label">Played</div></div>
    <div class="stat-box"><div class="stat-num">${pct}%</div><div class="stat-label">Win %</div></div>
    <div class="stat-box"><div class="stat-num">${stats.streak}</div><div class="stat-label">Streak</div></div>
    <div class="stat-box"><div class="stat-num">${stats.maxStreak}</div><div class="stat-label">Best</div></div>
  `;
  const maxDist = Math.max(...stats.dist, 1);
  const labels = ['1','2','3','4','5','X'];
  const todayGuesses = (() => {
    const s = loadDayState(getDayIndex(getTodayStr()));
    return (s.finished && s.won) ? s.guesses.length : null;
  })();
  document.getElementById('guessDist').innerHTML = `
    <div class="dist-label">Guess Distribution</div>
    ${stats.dist.map((v,i) => `
      <div class="dist-row">
        <div class="dist-num">${labels[i]}</div>
        <div class="dist-bar-wrap">
          <div class="dist-bar-fill ${todayGuesses === i+1 ? 'highlight' : ''}" style="width:${Math.round(v/maxDist*100)}%">
            <span>${v}</span>
          </div>
        </div>
      </div>
    `).join('')}
  `;
}

function renderArchiveModal() {
  const content = document.getElementById('archiveContent');
  const todayIdx = getDayIndex(getTodayStr());
  const totalDays = Math.min(todayIdx + 1, DISCS.length);

  let html = '<h2>Archive</h2><p style="margin-bottom:12px;">Play any previous day\'s disc.</p>';
  html += '<div class="archive-grid">';

  for (let i = 0; i < totalDays; i++) {
    const state = loadDayState(i);
    let cls = '';
    if (i === todayIdx) cls = 'today';
    else if (state.finished && state.won) cls = 'played-win';
    else if (state.finished && !state.won) cls = 'played-lose';
    const disc = DISCS[i % DISCS.length];
    const label = i + 1;
    html += `<div class="archive-day ${cls}" onclick="playArchiveDay(${i})" title="Day ${label}${disc ? ' · ' + disc.name : ''}">${label}</div>`;
  }
  html += '</div>';
  content.innerHTML = html;
}

function playArchiveDay(dayIndex) {
  const todayIdx = getDayIndex(getTodayStr());
  if (dayIndex === todayIdx) {
    closeModal('archive');
    return;
  }
  isArchiveMode = true;
  archiveDayIndex = dayIndex;
  archiveDisc = DISCS[dayIndex % DISCS.length];
  const state = loadDayState(dayIndex);
  closeModal('archive');
  renderArchiveGame(archiveDisc, state, dayIndex);
}

function renderArchiveGame(disc, state, dayIndex) {
  // Show archive header above game
  let header = document.getElementById('archiveGameHeader');
  if (!header) {
    header = document.createElement('div');
    header.id = 'archiveGameHeader';
    header.className = 'archive-game-header';
    header.style.cssText = 'max-width:640px;width:calc(100% - 32px);margin:14px auto 0;';
    document.getElementById('mainGame').insertBefore(header, document.getElementById('gameContent'));
  }
  header.innerHTML = `
    <div>
      <div class="archive-game-label">Archive — Day ${dayIndex + 1}</div>
      <div class="archive-game-date">Disc #${dayIndex + 1}</div>
    </div>
    <button class="back-btn" onclick="exitArchiveMode()">← Back to Today</button>
  `;
  renderGame(disc, state, dayIndex);
}

function exitArchiveMode() {
  isArchiveMode = false;
  archiveDayIndex = null;
  archiveDisc = null;
  const header = document.getElementById('archiveGameHeader');
  if (header) header.remove();
  const todayIdx = getDayIndex(getTodayStr());
  const state = loadDayState(todayIdx);
  renderGame(todayDisc, state, todayIdx);
}

